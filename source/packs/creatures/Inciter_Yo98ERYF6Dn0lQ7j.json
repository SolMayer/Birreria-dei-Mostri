		{
			"type": "action",
			"name": "Rampage",
			"system": {
				"actionType": {
					"value": "reaction"
				},
				"description": {
					"value": "<p><strong>Trigger</strong> the inciter reduces a creature to 0 hp with a Strike;</p><hr /><p><strong>Effect</strong> the inciter [[/act stride]]{Strides} once towards an enemy creature it can see. If it ends its movement within reach of that creature, it can attempt a single melee Strike, counting the multiple attack penalty as normal.</p><p></p>",
