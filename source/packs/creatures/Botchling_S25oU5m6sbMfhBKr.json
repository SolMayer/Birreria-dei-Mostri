		{
			"type": "action",
			"name": "Feverish Hunger",
			"system": {
				"actionType": {
					"value": "action"
				},
				"description": {
					"value": "<p>The Botchling can target an @UUID[Compendium.pf2e.conditionitems.Item.fBnFDH2MTzgFijKf]{Unconscious} creature, within 5ft from him. That creature must attempt a @Check[will|dc:15] Save. A creature that has already the @UUID[Compendium.pf2e.conditionitems.Item.4D2KBtexWXa6oUMR]{Drained} condition increases its condition by 1 if they fails (or by 2 if they critically fails).</p><hr /><p><strong>Critical Success</strong> the creature is unaffected and wakes up immediately.</p><p><strong>Success</strong> the creature is unaffected but doesn't wake up.</p><p><strong>Failure</strong> the creature become @UUID[Compendium.pf2e.conditionitems.Item.4D2KBtexWXa6oUMR]{Drained 1} and wakes up after one round.</p><p><strong>Critical Failure</strong> the creature become @UUID[Compendium.pf2e.conditionitems.Item.4D2KBtexWXa6oUMR]{Drained 2} but doesn't wake up</p>",
					"gm": ""
				},
