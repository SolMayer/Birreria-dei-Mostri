		{
			"type": "action",
			"name": "Charge",
			"system": {
				"actionType": {
					"value": "action"
				},
				"description": {
					"value": "<p>The Gorebull [[/act stride]]{Strides} twice and attempts a single gore Strike. If they hit, target creature must attempt at a @Check[fortitude|dc:22|options:damaging-effect] save.</p><hr /><p><strong>Critical Success</strong> the creature is unaffected.</p><p><strong>Success</strong> the creature is pushed back by 5 feet.</p><p><strong>Failure</strong> the creature is pushed back by 10 feet and falls @UUID[Compendium.pf2e.conditionitems.Item.j91X7x0XSomq8d60]{Prone}.</p><p><strong>Critical Failure</strong> As failure but the creature is also impaled by the Gorebull's horn, taking @Damage[4d6[bleed,persistent]]damage.</p>",
					"gm": ""
				},
