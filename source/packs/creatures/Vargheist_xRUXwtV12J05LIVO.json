		{
			"type": "action",
			"name": "Diving Attack",
			"system": {
				"actionType": {
					"value": "action"
				},
				"description": {
					"value": "<p><strong>Requirements</strong> The Vargheist is flying</p><hr /><p> The Vargheist dives towards a creature it can see within 40 feet of it, attempint a single Claw Strike. If it hits, target creature must attempt at a @Check[fortitude|dc:23] save or be knocked @UUID[Compendium.pf2e.conditionitems.Item.j91X7x0XSomq8d60]{Prone} or considered @UUID[Compendium.pf2e.conditionitems.Item.kWc1fhmv9LBiTuei]{Grabbed} by the vargheist (as chosen by the vargheist). Whenever the vargheist has a creature grabbed by Diving Attack, it can move, dragging the creature with them without breaking the grab. This counts as two attacks when calculating the vargheist's multiple attack penalty.</p>",
					"gm": ""
				},
