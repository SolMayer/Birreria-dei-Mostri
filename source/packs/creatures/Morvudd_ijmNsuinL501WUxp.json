		{
			"type": "action",
			"name": "Blinding Gaze",
			"system": {
				"actionType": {
					"value": "passive"
				},
				"description": {
					"value": "<p>Whenever a creature starts their turn within 30 feet of the morvudd and can see its third eye, they must attempt at a @Check[will|dc:31] save.</p><hr /><p><strong>Critical Success</strong> The creature is unaffected and immune for 24h.</p><p><strong>Success</strong> The creature is @UUID[Compendium.pf2e.conditionitems.Item.TkIyaNPgTZFBCCuh]{Dazzled} for 1 round.</p><p><strong>Failure</strong> The creature is @UUID[Compendium.pf2e.conditionitems.Item.XgEqL1kFApUbl5Z2]{Blinded} for 1 round and dazzled for 1 round after that.</p><p><strong>Critical Failure</strong> The creature is Blinded for 1 round and dazzled for 1 minute after that.</p>",
