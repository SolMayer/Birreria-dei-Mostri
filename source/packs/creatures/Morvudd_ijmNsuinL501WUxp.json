		{
			"type": "action",
			"name": "Devastating Charge",
			"system": {
				"actionType": {
					"value": "action"
				},
				"description": {
					"value": "<p>The Morvudd [[/act stride]]{Strides} twice and attempt a single antler Strike against a creature within reach. If the Morvudd hits, target creature must attempt at a @Check[reflex|dc:31] save or be pushed back by 5 feet (the creature is pushed back by 10 feet and knocked @UUID[Compendium.pf2e.conditionitems.Item.j91X7x0XSomq8d60]{Prone} with a critical failure).</p>",
