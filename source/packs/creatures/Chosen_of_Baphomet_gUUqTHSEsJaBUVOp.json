		{
			"type": "action",
			"name": "Baphomet's Charge",
			"system": {
				"actionType": {
					"value": "action"
				},
				"description": {
					"value": "<p>The Chosen of Baphomet [[/act stride]]{Strides} twice and attempts a single gore Strike. If they hit, target creature must attempt at a @Check[fortitude|dc:33] save.</p><hr /><p><strong>Critical Success</strong> The creature takes the strike's damage, without any further effects.</p><p><strong>Success</strong> The creature is pushed back by 5 feet.</p><p><strong>Failure</strong> The creature is pushed back by 10 feet and takes @Damage[3d6[bleed,persistent]] damage as the minotaur's horns pierce through them.</p><p><strong>Critical Failure</strong> The creature is not pushed back, but instead is @UUID[Compendium.pf2e.conditionitems.Item.eIcWbB5o3pP6OIMe]{Immobilized} as the chosen of baphomet impales them with its horn, dealing an additional @Damage[6d6[bleed,persistent]] damage.</p>",
					"gm": ""
				},
