		{
			"type": "action",
			"name": "Stir the Rage of Baphomet",
			"system": {
				"actionType": {
					"value": "action"
				},
				"description": {
					"value": "<p>The Chosen of Baphomet targets a creature within 30 feet of him, channeling the power of Baphomet to make them furious and confused. Target creature takes @Damage[16d6[mental]] damage and must attempt at a @Check[will|dc:33|traits:incapacitation,mental|options:damaging-effect] Save.</p><hr /><p><strong>Critical Success</strong> the creature is unaffected</p><p><strong>Success</strong> the creature take half damage and is @UUID[Compendium.pf2e.conditionitems.Item.yblD8fOR1J8rDwEQ]{Confused} until the end of its next turn.</p><p><strong>Failure</strong> the creature take full damage and is confused for two turns.</p><p><strong>Critical Failure</strong> as failure and the creature is confused for 1 minute.</p>",
					"gm": ""
				},
