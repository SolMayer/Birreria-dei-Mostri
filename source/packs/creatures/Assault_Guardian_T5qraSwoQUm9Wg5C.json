		{
			"type": "action",
			"name": "Reel",
			"system": {
				"actionType": {
					"value": "action"
				},
				"description": {
					"value": "<p><strong>Requirements</strong> the assault guardian's most recent action is a hit or critically hit with a harpoon Strike;</p><hr /><p>the assault guardian attempts to drag the creature it hits towards him. Attempt an @Check[athletics|against:fortitude] checks against the target's fortitude DC.</p><hr /><p><strong>Critical Success</strong> the assault guardian [[/act reposition]] the creature by 10 feet toward itself.</p><p><strong>Success</strong> the assault guardian [[/act reposition]] the creature by 5 feet toward itself.</p><p><strong>Failure</strong> the assault guardian doesn't [[/act reposition]] the creature.</p><p><strong>Critical Failure</strong> as failure, but the strain exercised on the tow takes its toll. The tow takes bludgeoning damage equal to the assault guardian's Strength modifier, ignoring the Hardness.</p>",
					"gm": ""
				},
