		{
			"type": "action",
			"name": "Bow of Holy Fire",
			"system": {
				"actionType": {
					"value": "action"
				},
				"description": {
					"value": "<p>Requirements the archon of fire must wielding a ranged weapon of the bow group; Effect By channeling the force of the celestial beings whom they serve, the archon of fire empowers its longbow, targeting an unholy being, like a fiend or an undead, before attempting a longbow strike. If the Strike hits, the creature must attempt at a @Check[will|dc:25] save. This counts as two Strikes when calculating the angel's multiple attack penalty. Any spirit damage is considered holy regarding the target's immunity, weaknesses or resistances.</p><hr /><p><strong>Critical Success</strong> the creature takes only the normal Strike damage.</p><p><strong>Success</strong> the creature takes additional spirit damage equal to the archon of fire's level.</p><p><strong>Failure</strong> the creature takes additional persistent spirit damage equal to the archon of fire's level.</p><p><strong>Critical Failure</strong> the creature takes additional persistent spirit damage equal to double the archon of fire's level</p>",
					"gm": ""
				},
				"publication": {
					"title": "",
					"authors": "",
					"license": "OGL",
					"remaster": false
				},
				"rules": [
					{
						"key": "RollOption",
						"option": "holy-bow",
						"toggleable": true
					},
					{
						"key": "Note",
						"selector": [
							"longbow-damage"
						],
						"outcome": [
							"success",
							"criticalSuccess"
						],
						"text": "Target unholy creature must attempt at a @Check[will|dc:25] save.Any spirit damage is considered holy regarding the target's immunity, weaknesses or resistances.</p>\n<hr>\n<p><strong>Critical Success</strong> the creature takes only the normal Strike damage.</p>\n<p><strong>Success</strong> the creature takes additional spirit damage equal to the archon of fire's level.</p>\n<p><strong>Failure</strong> the creature takes additional persistent spirit damage equal to the archon of fire's level.</p>\n<p><strong>Critical Failure</strong> the creature takes additional persistent spirit damage equal to double the archon of fire's level</p>",
						"predicate": [
							"holy-bow",
							"target:trait:unholy"
